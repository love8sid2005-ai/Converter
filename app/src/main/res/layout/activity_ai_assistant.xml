<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Премиум хедер -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="48dp"
        android:paddingBottom="20dp"
        android:background="@drawable/gradient_premium_header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <ImageView
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="10dp"
                android:background="@drawable/circle_accent_light"
                android:tint="@color/accent"
                android:clickable="true"
                android:focusable="true" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivAiAvatar"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_ai_assistant"
                    android:tint="@color/accent"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Ассистент"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/tvAiStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Онлайн"
                    android:textSize="12sp"
                    android:textColor="@color/success"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <ImageView
                android:id="@+id/clearChatButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_delete"
                android:padding="10dp"
                android:background="@drawable/circle_accent_light"
                android:tint="@color/accent"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>

    <!-- Список сообщений -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"
        android:orientation="vertical"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        android:stackFromBottom="true" />

    <!-- Индикатор печати -->
    <TextView
        android:id="@+id/tvAiTyping"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AI печатает"
        android:textSize="12sp"
        android:textColor="@color/accent"
        android:padding="8dp"
        android:layout_marginStart="16dp"
        android:visibility="gone" />

    <!-- Блок быстрых действий -->
    <HorizontalScrollView
        android:id="@+id/quickActionsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="12dp"
        android:scrollbars="none"
        android:visibility="visible">

        <LinearLayout
            android:id="@+id/quickActionsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

    </HorizontalScrollView>

    <!-- Поле ввода -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface"
        android:padding="12dp"
        android:elevation="8dp">

        <EditText
            android:id="@+id/messageInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Напишите сообщение..."
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:background="@drawable/chat_input_background"
            android:padding="14dp"
            android:maxLines="3"
            android:inputType="textMultiLine"
            android:fontFamily="sans-serif" />

        <ImageView
            android:id="@+id/sendButton"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_send"
            android:background="@drawable/circle_accent_light"
            android:tint="@color/accent"
            android:layout_marginStart="8dp"
            android:padding="14dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>