<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Логотип -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💰"
                    android:textSize="48sp" />

                <TextView
                    android:layout_width="62dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="-0.5"
                    android:text="Currency Converter"
                    android:textColor="@color/accent"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Войдите в свой аккаунт"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- Форма входа -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_premium_background"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="your@email.com"
                    android:textColorHint="@color/text_disabled"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/card_premium_background"
                    android:padding="16dp"
                    android:inputType="textEmailAddress"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Пароль"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="••••••••"
                    android:textColorHint="@color/text_disabled"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/card_premium_background"
                    android:padding="16dp"
                    android:inputType="textPassword"
                    android:fontFamily="sans-serif"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvForgotPassword"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Забыли пароль?"
                    android:textSize="12sp"
                    android:textColor="@color/accent"
                    android:layout_gravity="end"
                    android:layout_marginBottom="24dp"
                    android:padding="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="Войти"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:background="@drawable/button_premium" />

            </LinearLayout>

            <!-- Социальный вход -->
            <LinearLayout
                android:id="@+id/socialLoginContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Или войдите через"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/ivGoogle"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_google"
                        android:padding="12dp"
                        android:background="@drawable/circle_accent_light"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:id="@+id/ivApple"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_apple"
                        android:padding="12dp"
                        android:background="@drawable/circle_accent_light"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginEnd="16dp" />

                    <ImageView
                        android:id="@+id/ivPhone"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_phone"
                        android:padding="12dp"
                        android:background="@drawable/circle_accent_light"
                        android:clickable="true"
                        android:focusable="true" />

                </LinearLayout>

            </LinearLayout>

            <!-- Биометрический вход -->
            <LinearLayout
                android:id="@+id/biometricLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:background="@drawable/card_premium_background"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_fingerprint"
                    android:tint="@color/accent"
                    android:layout_marginEnd="12dp" />

                <TextView
                    android:id="@+id/tvBiometricText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Войти по отпечатку пальца"
                    android:textSize="14sp"
                    android:textColor="@color/accent" />

            </LinearLayout>

            <!-- Регистрация -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Нет аккаунта?"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvRegister"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" Зарегистрироваться"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent"
                    android:padding="4dp"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Overlay загрузки -->
    <View
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone" />

</LinearLayout>