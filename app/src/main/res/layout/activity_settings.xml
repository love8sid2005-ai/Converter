<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Премиум хедер -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="48dp"
                android:paddingBottom="24dp"
                android:background="@drawable/gradient_premium_header">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="20dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/ivBack"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_arrow_back"
                        android:padding="10dp"
                        android:background="@drawable/circle_accent_light"
                        android:tint="@color/accent"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/pageTitle"
                        android:layout_width="260dp"
                        android:layout_height="3dp"
                        android:layout_weight="1"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:letterSpacing="-0.5"
                        android:text="Настройки"
                        android:textColor="@color/text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="44dp"
                        android:layout_height="44dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Управление аккаунтом и предпочтениями"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
            <!-- Основные настройки -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_premium_background"
                android:layout_margin="16dp"
                android:padding="20dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ОСНОВНЫЕ"
                    android:textSize="12sp"
                    android:textColor="@color/accent"
                    android:textAllCaps="true"
                    android:layout_marginBottom="16dp" />

                <!-- Уведомления -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/card_premium_background"
                    android:layout_marginBottom="4dp"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Уведомления"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <Switch
                        android:id="@+id/switchNotifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:thumbTint="@color/accent"
                        android:trackTint="@color/text_disabled" />

                </RelativeLayout>

                <!-- Биометрический вход -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/card_premium_background"
                    android:layout_marginBottom="4dp"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Биометрический вход"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <Switch
                        android:id="@+id/switchBiometric"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:thumbTint="@color/accent"
                        android:trackTint="@color/text_disabled" />

                </RelativeLayout>

                <!-- Темная тема -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/card_premium_background"
                    android:layout_marginBottom="4dp"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Темная тема"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <Switch
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:thumbTint="@color/accent"
                        android:trackTint="@color/text_disabled" />

                </RelativeLayout>

                <!-- PIN-код -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:background="@drawable/card_premium_background"
                    android:layout_marginBottom="4dp"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PIN-код"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:layout_centerVertical="true"
                        android:layout_alignParentStart="true" />

                    <Switch
                        android:id="@+id/switchPinCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:thumbTint="@color/accent"
                        android:trackTint="@color/text_disabled" />

                </RelativeLayout>

                <!-- Статус PIN-кода и кнопка изменения -->
                <LinearLayout
                    android:id="@+id/pinCodeContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_premium_background"
                    android:padding="16dp"
                    android:layout_marginTop="4dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Статус:"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:id="@+id/tvPinCodeStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Не установлен"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary" />

                    <Button
                        android:id="@+id/btnChangePin"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="Изменить"
                        android:textSize="12sp"
                        android:textColor="@color/accent"
                        android:background="@drawable/button_outline_white"
                        android:layout_marginStart="16dp"
                        android:visibility="gone" />

                </LinearLayout>

            </LinearLayout>

            <!-- Настройки приложения -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_premium_background"
                android:layout_margin="16dp"
                android:padding="20dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ПРИЛОЖЕНИЕ"
                    android:textSize="12sp"
                    android:textColor="@color/accent"
                    android:textAllCaps="true"
                    android:layout_marginBottom="16dp" />

                <!-- Язык -->
                <LinearLayout
                    android:id="@+id/tvLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/card_premium_background"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Язык"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvLanguageValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Русский"
                        android:textSize="14sp"
                        android:textColor="@color/accent"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="20sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <!-- Основная валюта -->
                <LinearLayout
                    android:id="@+id/tvCurrency"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/card_premium_background"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Основная валюта"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:id="@+id/tvCurrencyValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="USD"
                        android:textSize="14sp"
                        android:textColor="@color/accent"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="20sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <!-- Безопасность -->
                <LinearLayout
                    android:id="@+id/tvSecurity"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/card_premium_background"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Безопасность"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="20sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

                <!-- О приложении -->
                <LinearLayout
                    android:id="@+id/tvAbout"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/card_premium_background"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="О приложении"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="›"
                        android:textSize="20sp"
                        android:textColor="@color/text_secondary" />

                </LinearLayout>

            </LinearLayout>

            <!-- Аккаунт -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/card_premium_background"
                android:layout_margin="16dp"
                android:padding="20dp"
                android:elevation="4dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="АККАУНТ"
                    android:textSize="12sp"
                    android:textColor="@color/accent"
                    android:textAllCaps="true"
                    android:layout_marginBottom="16dp" />

                <!-- Выйти -->
                <LinearLayout
                    android:id="@+id/tvLogout"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/card_premium_background"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Выйти из аккаунта"
                        android:textSize="16sp"
                        android:textColor="@color/error" />

                </LinearLayout>

                <!-- Удалить аккаунт -->
                <Button
                    android:id="@+id/btnDeleteAccount"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:text="Удалить аккаунт"
                    android:textSize="14sp"
                    android:textColor="@color/error"
                    android:background="@drawable/button_outline_white"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>