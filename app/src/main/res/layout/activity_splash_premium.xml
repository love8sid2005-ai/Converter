<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_splash_bg"
    android:gravity="center">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Логотип с анимацией -->
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp">

            <ImageView
                android:id="@+id/logoImage"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:src="@drawable/ic_launcher_foreground"
                android:tint="@color/accent" />

            <ImageView
                android:id="@+id/waveImage"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/ic_wave"
                android:tint="@color/accent"
                android:alpha="0.3"
                android:layout_centerInParent="true" />

        </RelativeLayout>

        <!-- Приветствие -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/emojiText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌅"
                android:textSize="32sp"
                android:layout_marginEnd="12dp" />

            <TextView
                android:id="@+id/greetingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Доброе утро!"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-light" />

        </LinearLayout>

        <!-- Время и дата -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/timeText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12:45"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@color/accent"
                android:fontFamily="sans-serif-light"
                android:letterSpacing="-0.02" />

            <TextView
                android:id="@+id/dateText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Понедельник, 24 марта 2026"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Цитата дня -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingLeft="32dp"
            android:paddingRight="32dp">

            <TextView
                android:id="@+id/quoteText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Финансовая свобода начинается здесь"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-light"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

            <TextView
                android:id="@+id/signatureText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— Currency Converter Team"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="12dp"
                android:alpha="0.7" />

        </LinearLayout>

    </LinearLayout>

    <!-- Нижняя часть -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Currency Converter"
            android:textSize="14sp"
            android:textColor="@color/text_disabled"
            android:letterSpacing="1" />

        <ProgressBar
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/accent"
            android:layout_marginTop="16dp" />

    </LinearLayout>

</LinearLayout>