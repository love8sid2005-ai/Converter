<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_premium_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="@drawable/gradient_premium_header_small">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.5"
                android:text="Аналитика"
                android:textColor="@color/text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif"
                android:text="Финансовые показатели"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:padding="10dp"
            android:background="@drawable/circle_accent_light"
            android:tint="@color/accent"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/card_premium_background"
        app:tabTextColor="@color/text_secondary"
        app:tabSelectedTextColor="@color/accent"
        app:tabIndicatorColor="@color/accent"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Обзор" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Транзакции" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Категории" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Тренды" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Content Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <!-- Overview Tab -->
        <LinearLayout
            android:id="@+id/contentOverview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="visible">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Баланс -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_premium_background"
                        android:padding="20dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Общий баланс"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:fontFamily="sans-serif" />

                        <TextView
                            android:id="@+id/tvTotalBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$12,450.75"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/accent"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Доходы"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:id="@+id/tvTotalIncome"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="$8,450.32"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/success" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="end">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Расходы"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:id="@+id/tvTotalExpense"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="$4,230.15"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/error" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- График баланса -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_premium_background"
                        android:padding="20dp"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Динамика баланса"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:id="@+id/tvWeeklyChange"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+3.2%"
                                    android:textSize="12sp"
                                    android:textColor="@color/success"
                                    android:layout_marginEnd="8dp" />

                                <TextView
                                    android:id="@+id/tvMonthlyChange"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="+12.5%"
                                    android:textSize="12sp"
                                    android:textColor="@color/success" />

                            </LinearLayout>

                        </LinearLayout>

                        <com.example.currencyconverter.views.SparklineChartView
                            android:id="@+id/chartBalance"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:layout_marginTop="16dp" />

                    </LinearLayout>

                    <!-- Статистика -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/card_premium_background"
                            android:padding="20dp"
                            android:layout_marginEnd="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Транзакций"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:id="@+id/tvTotalTransactions"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="47"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/accent"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/card_premium_background"
                            android:padding="20dp"
                            android:layout_marginStart="6dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Средний чек"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="$265"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="@color/accent"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

        </LinearLayout>

        <!-- Transactions Tab -->
        <LinearLayout
            android:id="@+id/contentTransactions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentTransactions"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="4dp" />

        </LinearLayout>

        <!-- Categories Tab -->
        <LinearLayout
            android:id="@+id/contentCategories"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Инвестиции -->
                    <LinearLayout
                        android:id="@+id/categoryInvestments"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/card_premium_background"
                        android:padding="16dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Инвестиции"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="52% от расходов"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvInvestmentsAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$3,240"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/success" />

                    </LinearLayout>

                    <!-- Покупки -->
                    <LinearLayout
                        android:id="@+id/categoryShopping"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/card_premium_background"
                        android:padding="16dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Покупки"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="20% от расходов"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvShoppingAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$1,250"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/warning" />

                    </LinearLayout>

                    <!-- Развлечения -->
                    <LinearLayout
                        android:id="@+id/categoryEntertainment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/card_premium_background"
                        android:padding="16dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Развлечения"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="14% от расходов"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvEntertainmentAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$890"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/info" />

                    </LinearLayout>

                    <!-- Еда -->
                    <LinearLayout
                        android:id="@+id/categoryFood"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/card_premium_background"
                        android:padding="16dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Еда"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="9% от расходов"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvFoodAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$560"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/success" />

                    </LinearLayout>

                    <!-- Транспорт -->
                    <LinearLayout
                        android:id="@+id/categoryTransport"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="@drawable/card_premium_background"
                        android:padding="16dp"
                        android:layout_marginBottom="8dp"
                        android:clickable="true"
                        android:focusable="true">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Транспорт"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5% от расходов"
                                android:textSize="11sp"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvTransportAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="$320"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

        </LinearLayout>

        <!-- Trends Tab -->
        <LinearLayout
            android:id="@+id/contentTrends"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Активность -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:background="@drawable/card_premium_background"
                        android:padding="20dp"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Пик активности"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="12dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Лучший день"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:id="@+id/tvBestDay"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Суббота"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/accent"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Лучший час"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:id="@+id/tvBestHour"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="14:00"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/accent"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Частая валюта"
                                    android:textSize="11sp"
                                    android:textColor="@color/text_secondary" />

                                <TextView
                                    android:id="@+id/tvMostUsedCurrency"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="USD"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/accent"
                                    android:layout_marginTop="4dp" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Тренды -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <LinearLayout
                            android:id="@+id/trendUp"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/card_premium_background"
                            android:padding="20dp"
                            android:layout_marginEnd="6dp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📈"
                                android:textSize="32sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Рост"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/success"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:id="@+id/tvTrendUpPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="+15.3%"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/success"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/trendDown"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/card_premium_background"
                            android:padding="20dp"
                            android:layout_marginStart="6dp"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="📉"
                                android:textSize="32sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Падение"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/error"
                                android:layout_marginTop="8dp" />

                            <TextView
                                android:id="@+id/tvTrendDownPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-8.7%"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/error"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>
            </ScrollView>

        </LinearLayout>

    </FrameLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/surface">

        <Button
            android:id="@+id/btnExport"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Экспорт"
            android:textSize="14sp"
            android:textColor="@color/accent"
            android:background="@drawable/filter_chip_inactive"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/btnRefresh"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Обновить"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/button_premium"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="20dp"
        android:text="Закрыть"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:background="@drawable/filter_chip_inactive"
        android:fontFamily="sans-serif-medium" />

</LinearLayout>