<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@color/accent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ФИНАНСОВЫЙ КАЛЬКУЛЯТОР"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_margin="16dp"
        android:background="@drawable/card_dark"
        app:tabTextColor="@color/text_secondary"
        app:tabSelectedTextColor="@color/accent"
        app:tabIndicatorColor="@color/accent"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="КРЕДИТ" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ИНВЕСТ" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ВАЛЮТА" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ИПОТЕКА" />

    </com.google.android.material.tabs.TabLayout>

    <!-- Loan Calculator -->
    <LinearLayout
        android:id="@+id/loanLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="СУММА КРЕДИТА"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvLoanAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$1,000,000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

            <com.google.android.material.slider.Slider
                android:id="@+id/loanAmountSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:valueFrom="100"
                android:valueTo="10000"
                android:value="1000"
                android:stepSize="100" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="СРОК (МЕСЯЦЫ)"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvLoanTerm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12 мес"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

            <com.google.android.material.slider.Slider
                android:id="@+id/loanTermSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:valueFrom="1"
                android:valueTo="360"
                android:value="12"
                android:stepSize="1" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ПРОЦЕНТНАЯ СТАВКА"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvLoanRate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="12.0%"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

            <com.google.android.material.slider.Slider
                android:id="@+id/loanRateSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:valueFrom="0.1"
                android:valueTo="30"
                android:value="12"
                android:stepSize="0.1" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/card_border"
            android:layout_marginVertical="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ЕЖЕМЕСЯЧНЫЙ ПЛАТЕЖ:"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvMonthlyPayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$8,888"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ОБЩАЯ СУММА:"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvTotalPayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$1,066,667"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ПЕРЕПЛАТА:"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvOverpayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$66,667"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/error" />

        </LinearLayout>

    </LinearLayout>

    <!-- Investment Calculator -->
    <LinearLayout
        android:id="@+id/investLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="СУММА ИНВЕСТИЦИЙ"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvInvestAmount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$10,000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

            <com.google.android.material.slider.Slider
                android:id="@+id/investAmountSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:valueFrom="10"
                android:valueTo="10000"
                android:value="100"
                android:stepSize="10" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="СРОК (ЛЕТ)"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvInvestTerm"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="5 лет"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

            <com.google.android.material.slider.Slider
                android:id="@+id/investTermSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:valueFrom="1"
                android:valueTo="30"
                android:value="5"
                android:stepSize="1" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ДОХОДНОСТЬ %"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvInvestRate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10.0%"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

            <com.google.android.material.slider.Slider
                android:id="@+id/investRateSlider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:valueFrom="0.1"
                android:valueTo="30"
                android:value="10"
                android:stepSize="0.1" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/card_border"
            android:layout_marginVertical="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ИТОГО:"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvFinalAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$16,105"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ПРИБЫЛЬ:"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvProfitAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$6,105"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/success" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ДОХОДНОСТЬ:"
                android:textSize="12sp"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/tvProfitPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+61.0%"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/success" />

        </LinearLayout>

    </LinearLayout>

    <!-- Currency Layout -->
    <LinearLayout
        android:id="@+id/currencyLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="40dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="КОНВЕРТЕР ВАЛЮТ"
            android:textColor="@color/accent"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <Button
            android:id="@+id/btnOpenConverter"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="ПЕРЕЙТИ В КОНВЕРТЕР"
            android:textColor="@color/white"
            android:background="@drawable/button_accent"
            android:layout_marginTop="20dp" />

    </LinearLayout>

    <!-- Mortgage Layout -->
    <LinearLayout
        android:id="@+id/mortgageLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="40dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ИПОТЕЧНЫЙ КАЛЬКУЛЯТОР"
            android:textColor="@color/accent"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="СКОРО"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginTop="20dp" />

    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp">

        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="РАССЧИТАТЬ"
            android:textColor="@color/white"
            android:background="@drawable/button_accent" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="СОХРАНИТЬ"
            android:textColor="@color/accent"
            android:background="@drawable/button_outline_white" />

        <Button
            android:id="@+id/btnShare"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="ПОДЕЛИТЬСЯ"
            android:textColor="@color/accent"
            android:background="@drawable/button_outline_white" />

    </LinearLayout>

    <Button
        android:id="@+id/btnClose"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="20dp"
        android:text="ЗАКРЫТЬ"
        android:textColor="@color/white"
        android:background="@drawable/button_accent" />

</LinearLayout>