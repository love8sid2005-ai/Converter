<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bottom_sheet_premium_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        android:background="@drawable/gradient_premium_header_small">

        <TextView
            android:layout_width="0dp"
            android:layout_height="4dp"
            android:layout_weight="1"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="-0.5"
            android:text="QR-код"
            android:textColor="@color/text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_close"
            android:padding="10dp"
            android:background="@drawable/circle_accent_light"
            android:tint="@color/accent"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="550dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Инструкция -->
            <TextView
                android:id="@+id/tvInstructions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Сгенерируйте QR-код для платежа"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="20dp" />

            <!-- Сумма платежа - заголовок -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Сумма платежа"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="8dp" />

            <!-- Новое крутое поле ввода суммы -->
            <com.example.currencyconverter.views.AmountEditText
                android:id="@+id/etCustomAmount"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:layout_marginBottom="16dp" />

            <!-- Пресеты сумм -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="20dp">

                <TextView
                    android:id="@+id/preset10"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="$10"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:background="@drawable/filter_chip_inactive"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/preset50"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="$50"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:background="@drawable/filter_chip_inactive"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/preset100"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="$100"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:background="@drawable/filter_chip_inactive"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/preset500"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="$500"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    android:background="@drawable/filter_chip_inactive"
                    android:clickable="true"
                    android:focusable="true" />

            </LinearLayout>

            <!-- QR-код -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/card_premium_background"
                android:padding="20dp"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:id="@+id/ivQrDisplay"
                    android:layout_width="220dp"
                    android:layout_height="220dp"
                    android:src="@drawable/ic_qr_placeholder"
                    android:background="@drawable/card_premium_background"
                    android:padding="16dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tvScanResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Нажмите на QR-код для оплаты"
                    android:textSize="12sp"
                    android:textColor="@color/accent"
                    android:gravity="center"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="16dp" />

            </LinearLayout>

            <!-- Кнопки -->
            <Button
                android:id="@+id/btnManualInput"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Ввести вручную"
                android:textSize="14sp"
                android:textColor="@color/accent"
                android:background="@drawable/filter_chip_inactive"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnGenerateQr"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Сгенерировать QR-код"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:background="@drawable/button_premium"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Закрыть"
                android:textSize="14sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/filter_chip_inactive"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="20dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>