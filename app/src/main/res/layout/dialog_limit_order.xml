<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/gradient_dialog_bg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Лимитный ордер"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Сумма USD"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etFromAmount"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="1000.00"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/white"
        android:background="@drawable/chat_input_background"
        android:padding="16dp"
        android:inputType="numberDecimal"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Желаемый курс"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="8dp" />

    <EditText
        android:id="@+id/etTargetRate"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="90.50"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/white"
        android:background="@drawable/chat_input_background"
        android:padding="16dp"
        android:inputType="numberDecimal"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnCreate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Создать ордер"
            android:textColor="@color/white"
            android:background="@drawable/button_accent" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Отмена"
            android:textColor="@color/white"
            android:background="@drawable/button_outline_white" />

    </LinearLayout>

</LinearLayout>