<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/gradient_dialog_bg">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ВВОД QR-ДАННЫХ"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/hack_green"
        android:gravity="center"
        android:fontFamily="monospace"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/etQrData"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:hint="PAYMENT:USER123:AMOUNT:1000"
        android:textColorHint="@color/text_secondary"
        android:textColor="@color/white"
        android:background="@drawable/card_dark"
        android:padding="12dp"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="ПОДТВЕРДИТЬ"
            android:textColor="@color/white"
            android:background="@drawable/button_red"
            android:fontFamily="monospace"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="ОТМЕНА"
            android:textColor="@color/white"
            android:background="@drawable/button_red"
            android:fontFamily="monospace"
            android:textAllCaps="false" />

    </LinearLayout>

</LinearLayout>