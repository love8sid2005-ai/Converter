<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/surface">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MAX APP"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_star_gold"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ваш личный финансовый помощник"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="• Умный конвертер валют\n• Аналитика рынка в реальном времени\n• Брокерский кабинет\n• AI-поддержка 24/7\n• Персональные рекомендации\n• Безопасные транзакции"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnWebsite"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Сайт"
            android:textColor="@color/white"
            android:background="@drawable/button_accent" />

        <Button
            android:id="@+id/btnClose"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Закрыть"
            android:textColor="@color/white"
            android:background="@drawable/button_outline_white" />

    </LinearLayout>

</LinearLayout>