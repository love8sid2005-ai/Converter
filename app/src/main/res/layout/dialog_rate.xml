<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/gradient_dialog_bg">

    <!-- Премиум хедер с золотым градиентом -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_premium_header"
        android:padding="20dp"
        android:layout_marginBottom="20dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ОЦЕНИТЕ ПРИЛОЖЕНИЕ"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:gravity="center"
            android:letterSpacing="1.5"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ваше мнение важно для нас"
            android:textSize="14sp"
            android:textColor="#80FFFFFF"
            android:gravity="center" />

        <!-- Анимированные звезды (иконки) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="16dp">

            <ImageView
                android:id="@+id/starIcon1"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_star_gold"
                android:layout_marginHorizontal="4dp" />

            <ImageView
                android:id="@+id/starIcon2"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_star_gold"
                android:layout_marginHorizontal="4dp" />

            <ImageView
                android:id="@+id/starIcon3"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_star_gold"
                android:layout_marginHorizontal="4dp" />

            <ImageView
                android:id="@+id/starIcon4"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_star_gold"
                android:layout_marginHorizontal="4dp" />

            <ImageView
                android:id="@+id/starIcon5"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_star_gold"
                android:layout_marginHorizontal="4dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Основной контент -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Секция выбора оценки -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Как вам наше приложение?"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginBottom="16dp" />

            <!-- Звезды для оценки -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:id="@+id/star1"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/star_premium"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textSize="36sp"
                        android:textColor="@color/premium_gold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/star2"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/star_premium"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textSize="36sp"
                        android:textColor="@color/premium_gold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/star3"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/star_premium"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textSize="36sp"
                        android:textColor="@color/premium_gold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/star4"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/star_premium"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textSize="36sp"
                        android:textColor="@color/premium_gold" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/star5"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/star_premium"
                    android:layout_marginHorizontal="4dp"
                    android:clickable="true"
                    android:focusable="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="★"
                        android:textSize="36sp"
                        android:textColor="@color/premium_gold" />

                </LinearLayout>

            </LinearLayout>

            <!-- Текст под звездами -->
            <TextView
                android:id="@+id/tvRateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Нажмите на звезды, чтобы оценить"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <!-- Бонусы за оценку -->
            <LinearLayout
                android:id="@+id/bonusSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/premium_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ВАШ БОНУС ЗА ОЦЕНКУ"
                    android:textSize="12sp"
                    android:textColor="#FFD700"
                    android:textAllCaps="true"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_gift"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="10$ на ваш счет"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_premium"
                        android:layout_marginEnd="12dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="7 дней Premium доступа"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                </LinearLayout>

            </LinearLayout>

            <!-- Форма обратной связи (для низких оценок) -->
            <LinearLayout
                android:id="@+id/feedbackSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/premium_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="РАССКАЖИТЕ, ЧТО МОЖНО УЛУЧШИТЬ?"
                    android:textSize="12sp"
                    android:textColor="#FFD700"
                    android:textAllCaps="true"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:hint="Ваш отзыв..."
                    android:textColorHint="@color/text_secondary"
                    android:textColor="@color/white"
                    android:background="@drawable/chat_input_background"
                    android:gravity="top"
                    android:padding="12dp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnSendFeedback"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:text="Отправить отзыв"
                    android:textColor="@color/white"
                    android:background="@drawable/button_accent" />

            </LinearLayout>

            <!-- Преимущества Premium -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/premium_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="PREMIUM ПРЕИМУЩЕСТВА"
                    android:textSize="12sp"
                    android:textColor="#FFD700"
                    android:textAllCaps="true"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="✓ Безлимитные конвертации"
                        android:textSize="14sp"
                        android:textColor="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Premium"
                        android:textSize="10sp"
                        android:textColor="#FFD700"
                        android:background="#33FFD700"
                        android:padding="4dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✓ Реальные курсы без задержки"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✓ Приоритетная поддержка 24/7"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="✓ Эксклюзивная аналитика"
                    android:textSize="14sp"
                    android:textColor="@color/white"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Кнопки действий -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnRate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Оценить"
            android:textColor="@color/white"
            android:background="@drawable/gradient_button_premium"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_horizontal">

            <Button
                android:id="@+id/btnLater"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Напомнить позже"
                android:textColor="@color/white"
                android:background="@drawable/button_outline_white"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnNever"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Больше не спрашивать"
                android:textColor="@color/text_secondary"
                android:background="@drawable/button_outline_gray"
                android:textSize="12sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>