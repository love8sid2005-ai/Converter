<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_premium_background"
    android:padding="24dp">

    <!-- Заголовок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_star_gold"
            android:tint="@color/accent"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Оцените приложение"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ваше мнение важно для нас"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Звезды оценки -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="20dp">

        <ImageView
            android:id="@+id/star1"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:tint="@color/text_disabled"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/star2"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:tint="@color/text_disabled"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/star3"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:tint="@color/text_disabled"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/star4"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:tint="@color/text_disabled"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <ImageView
            android:id="@+id/star5"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_star_outline"
            android:tint="@color/text_disabled"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- Текст оценки -->
    <TextView
        android:id="@+id/tvRateMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нажмите на звезду, чтобы оценить"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="20dp" />

    <!-- Бонусная секция (показывается при 5 звездах) -->
    <LinearLayout
        android:id="@+id/bonusSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_card_premium"
        android:padding="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_gift"
                android:tint="@color/accent"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Бонус за оценку!"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/accent" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="$10 на счет"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textSize="13sp"
                android:textColor="@color/success" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="7 дней Premium доступа"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textSize="13sp"
                android:textColor="@color/success" />

        </LinearLayout>

    </LinearLayout>

    <!-- Форма обратной связи (для низких оценок) -->
    <LinearLayout
        android:id="@+id/feedbackSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Что можно улучшить?"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etFeedback"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:hint="Напишите ваш отзыв..."
            android:textColorHint="@color/text_disabled"
            android:textColor="@color/text_primary"
            android:background="@drawable/card_premium_background"
            android:gravity="top"
            android:padding="12dp"
            android:maxLines="3" />

    </LinearLayout>

    <!-- Кнопки -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <Button
            android:id="@+id/btnRate"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Оценить"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/button_premium"
            android:enabled="false"
            android:alpha="0.5" />

        <Button
            android:id="@+id/btnSendFeedback"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Отправить"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/button_premium"
            android:visibility="gone" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnLater"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Напомнить позже"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:background="@drawable/filter_chip_inactive" />

        <Button
            android:id="@+id/btnNever"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Больше не спрашивать"
            android:textSize="12sp"
            android:textColor="@color/text_disabled"
            android:background="@drawable/filter_chip_inactive" />

    </LinearLayout>

</LinearLayout>