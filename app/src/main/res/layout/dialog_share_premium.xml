<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_premium_background"
    android:padding="24dp">

    <!-- Заголовок -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="16dp">

        <ImageView
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:src="@drawable/ic_share"
            android:tint="@color/accent"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Поделиться"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Расскажите друзьям о приложении"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Способы поделиться -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/gradient_card_premium"
        android:padding="16dp"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Способы поделиться"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/accent"
            android:layout_marginBottom="12dp" />

        <!-- Соцсети -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <ImageView
                android:id="@+id/shareTelegram"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_telegram"
                android:padding="10dp"
                android:background="@drawable/circle_accent_light"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/shareVk"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_vk"
                android:padding="10dp"
                android:background="@drawable/circle_accent_light"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="12dp" />

            <ImageView
                android:id="@+id/shareWhatsapp"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_whatsapp"
                android:padding="10dp"
                android:background="@drawable/circle_accent_light"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- QR код -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_premium_background"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_qr"
                android:tint="@color/accent"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Показать QR-код"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="@color/accent" />

        </LinearLayout>

        <!-- Скопировать ссылку -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_premium_background"
            android:padding="12dp">

            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_copy"
                android:tint="@color/accent"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Скопировать ссылку"
                android:textSize="14sp"
                android:textColor="@color/text_primary" />

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_arrow_right"
                android:tint="@color/accent" />

        </LinearLayout>

    </LinearLayout>

    <!-- Бонус за приглашение -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/card_premium_background"
        android:padding="12dp"
        android:layout_marginBottom="20dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_gift"
            android:tint="@color/success"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="За каждого друга, установившего приложение, вы получаете $5 бонуса!"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- Кнопки -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnShareSystem"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Поделиться"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/button_premium" />

        <Button
            android:id="@+id/btnShareClose"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Закрыть"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:background="@drawable/filter_chip_inactive" />

    </LinearLayout>

</LinearLayout>