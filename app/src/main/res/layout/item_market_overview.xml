<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="140dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_premium_background"
    android:padding="12dp"
    android:layout_marginEnd="12dp"
    android:gravity="center">

    <ImageView
        android:id="@+id/ivMarketIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvMarketName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="S&amp;P 500"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/tvMarketValue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="5,234.45"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvMarketChange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+1.24%"
        android:textSize="11sp"
        android:layout_marginTop="2dp" />

</LinearLayout>