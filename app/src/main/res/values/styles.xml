<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Card Style -->
    <style name="CardStyle">
        <item name="android:background">@drawable/bg_card_dark</item>
        <item name="android:elevation">4dp</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Primary Button (Оранжевый градиент) -->
    <style name="ButtonPrimary">
        <item name="android:background">@drawable/bg_gradient_orange</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- Secondary Button (Обводка оранжевая) -->
    <style name="ButtonSecondary">
        <item name="android:background">@drawable/bg_button_outline_orange</item>
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:paddingHorizontal">24dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:gravity">center</item>
    </style>

    <!-- EditText Style -->
    <style name="EditTextStyle">
        <item name="android:background">@drawable/bg_edittext_dark</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:padding">16dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- Bottom Navigation Style -->
    <style name="BottomNavigationStyle">
        <item name="android:background">@color/surface</item>
        <item name="android:elevation">8dp</item>
    </style>

    <!-- TabLayout Style -->
    <style name="TabLayoutStyle">
        <item name="tabIndicatorColor">@color/accent</item>
        <item name="tabSelectedTextColor">@color/accent</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="android:background">@color/surface</item>
    </style>

    <!-- Section Title -->
    <style name="SectionTitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>

    <!-- Price Up (Зеленый) -->
    <style name="PriceUp">
        <item name="android:textColor">@color/success</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Price Down (Красный) -->
    <style name="PriceDown">
        <item name="android:textColor">@color/error</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Premium Dialog Theme -->
    <style name="PremiumDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:background">@drawable/card_premium_background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:windowBackground">@drawable/card_premium_background</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>
</resources>