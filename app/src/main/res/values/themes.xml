<resources>
    <style name="Theme.CurrencyConverter" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary Colors (Bybit Orange) -->
        <item name="colorPrimary">@color/bybit_orange</item>
        <item name="colorPrimaryVariant">@color/bybit_orange_dark</item>
        <item name="colorOnPrimary">@color/bybit_text_primary</item>

        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/bybit_orange_dark</item>
        <item name="colorOnSecondary">@color/bybit_text_primary</item>

        <!-- Surface & Background (Dark Theme Default) -->
        <item name="colorSurface">@color/bybit_surface</item>
        <item name="colorOnSurface">@color/bybit_text_primary</item>

        <!-- ИСПРАВЛЕНО: Используем стандартный android:colorBackground -->
        <item name="android:colorBackground">@color/bybit_bg</item>
        <item name="colorOnBackground">@color/bybit_text_primary</item>

        <!-- Error Colors -->
        <item name="colorError">@color/bybit_error</item>
        <item name="colorOnError">@color/bybit_text_primary</item>

        <!-- System Bars -->
        <item name="android:statusBarColor">@color/bybit_bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bybit_surface</item>

        <!-- Default Text Colors -->
        <item name="android:textColorPrimary">@color/bybit_text_primary</item>
        <item name="android:textColorSecondary">@color/bybit_text_secondary</item>
        <item name="android:textColorHint">@color/bybit_text_disabled</item>

        <!-- Window Background -->
        <item name="android:windowBackground">@color/bybit_bg</item>

        <!-- Font Family -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Дополнительные стили для кнопок и карточек в стиле Bybit -->
    <style name="ButtonPrimaryBybit" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/bybit_gradient_start</item>
        <item name="android:textColor">@color/bybit_text_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="CardStyleBybit">
        <item name="cardBackgroundColor">@color/bybit_card</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/bybit_border</item>
        <item name="strokeWidth">1dp</item>
    </style>
</resources>